---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Fluidity Marine — Active Boundary Layer Thrust Vectoring. The Operating System of the Water." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <div class="nav-content">
        <a href="/" class="logo-link">FLUIDITY<span class="logo-accent">MARINE</span></a>
        <div class="links">
          <a href="/technology">Technology</a>
          <a href="/about">About</a>
          <a href="/investors">Investors</a>
          <a href="/press">Press</a>
          <a href="https://wefunder.com/fluidity" class="nav-button">Invest Now</a>
        </div>
      </div>
    </nav>
    <slot />
    <footer>
      <div class="footer-content">
        <div class="footer-brand">
          <strong class="footer-logo">FLUIDITY MARINE</strong>
          <p>A division of InnovativeDynamix</p>
        </div>
        <div class="footer-links">
          <a href="/technology">Technology</a>
          <a href="/about">About</a>
          <a href="/investors">Investors</a>
          <a href="/press">Press</a>
        </div>
        <div class="footer-social">
          <span>&copy; 2026 InnovativeDynamix. All rights reserved.</span>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --cyan: #00f2fe;
    --blue: #4facfe;
    --purple: #7c3aed;
    --bg: #050a0f;
    --bg-card: rgba(255, 255, 255, 0.03);
    --bg-glass: rgba(15, 23, 42, 0.7);
    --text: #e2e8f0;
    --text-muted: #94a3b8;
    --border: rgba(255, 255, 255, 0.08);
    --border-light: rgba(255, 255, 255, 0.05);
    --gradient-cyan: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    --gradient-electric: linear-gradient(to right, #00f2fe, #4facfe);
    --shadow-cyan: rgba(0, 242, 254, 0.2);
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 20px;
    --radius-xl: 24px;
    --radius-2xl: 32px;
  }

  * { box-sizing: border-box; }

  html {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
  }

  ::selection {
    background: rgba(0, 242, 254, 0.3);
    color: #fff;
  }

  /* ─── Navigation ─── */
  nav {
    border-bottom: 1px solid var(--border-light);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    background: rgba(5, 10, 15, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    z-index: 100;
  }

  .nav-content {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 2rem;
  }

  .logo-link {
    font-weight: 800;
    font-size: 1.2rem;
    text-decoration: none;
    color: #fff;
    letter-spacing: 0.08em;
  }

  .logo-accent {
    color: var(--cyan);
    margin-left: 2px;
  }

  .links { display: flex; gap: 2rem; align-items: center; }

  .links a {
    text-decoration: none;
    color: var(--text-muted);
    font-weight: 500;
    font-size: 0.9rem;
    transition: color 0.2s;
    position: relative;
  }

  .links a:hover { color: var(--cyan); }

  .links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--gradient-cyan);
    transition: width 0.2s ease;
  }

  .links a:hover::after { width: 100%; }

  .nav-button {
    background: var(--gradient-cyan) !important;
    color: #050a0f !important;
    padding: 0.6rem 1.3rem;
    border-radius: var(--radius-sm);
    font-weight: 700 !important;
    box-shadow: 0 0 20px rgba(0, 242, 254, 0.2);
    transition: all 0.2s !important;
  }

  .nav-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 30px rgba(0, 242, 254, 0.35) !important;
  }

  .nav-button::after { display: none !important; }

  /* ─── Footer ─── */
  footer {
    border-top: 1px solid var(--border-light);
    padding: 3rem 2rem;
  }

  .footer-content {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-logo {
    color: #fff;
    font-size: 0.95rem;
    letter-spacing: 0.06em;
  }

  .footer-brand p {
    color: var(--text-muted);
    font-size: 0.8rem;
    margin: 0.3rem 0 0;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--cyan); }

  .footer-social span {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  /* ─── Utility ─── */
  .electric-text {
    background: var(--gradient-electric);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 6rem 2rem;
  }

  .page-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.05;
    margin: 0 0 1.5rem;
    color: #fff;
    letter-spacing: -0.03em;
  }

  .page-subtitle {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin: 0 0 4rem;
    max-width: 650px;
    line-height: 1.7;
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 2.5rem;
    border-radius: var(--radius-xl);
    transition: all 0.3s ease;
  }

  .card:hover {
    border-color: rgba(79, 172, 254, 0.2);
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-2px);
  }

  .card h2, .card h3 {
    font-size: 1.4rem;
    color: #fff;
    margin: 0 0 1rem;
  }

  .card p {
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-bottom: 5rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    border-radius: var(--radius-md);
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s ease;
    cursor: pointer;
    border: none;
    font-size: 0.95rem;
  }

  .button-primary {
    background: var(--gradient-cyan);
    color: #050a0f;
    box-shadow: 0 8px 25px rgba(0, 242, 254, 0.2);
  }

  .button-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 35px rgba(0, 242, 254, 0.3);
  }

  .button-secondary {
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
    border: 1px solid var(--border);
  }

  .button-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
  }

  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 1rem;
    color: #fff;
  }

  .section-subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 3rem;
    max-width: 600px;
    line-height: 1.7;
  }

  .divider {
    border: none;
    height: 1px;
    background: var(--border-light);
    margin: 5rem 0;
  }

  .glass-box {
    background: var(--bg-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    padding: 2.5rem;
    border-radius: var(--radius-xl);
  }

  /* ─── Animations ─── */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0, 242, 254, 0.6); }
    50% { box-shadow: 0 0 0 15px rgba(0, 242, 254, 0); }
  }

  .animate-in {
    animation: fadeInUp 0.6s ease forwards;
    opacity: 0;
  }

  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
  .delay-4 { animation-delay: 0.4s; }
  .delay-5 { animation-delay: 0.5s; }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .links a:not(.nav-button) { display: none; }
    .card-grid { grid-template-columns: 1fr; }
    .page { padding: 4rem 1.5rem; }
    .footer-content { flex-direction: column; text-align: center; }
  }
</style>
