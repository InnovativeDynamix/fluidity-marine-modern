---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Fluidity Marine: The Operating System of the Water" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<nav>
			<div class="nav-content">
				<a href="/" class="logo-link">Fluidity Marine</a>
				<div class="links">
					<a href="/technology">Technology</a>
					<a href="/investors">Investors</a>
					<a href="https://wefunder.com/fluidity" class="nav-button">Invest Now</a>
				</div>
			</div>
		</nav>
		<slot />
		<footer>
			<p>&copy; 2026 InnovativeDynamix / Fluidity Marine. All rights reserved.</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--cyan: #00f2fe;
		--blue: #4facfe;
		--bg: #050a0f;
		--text: #e2e8f0;
		--text-muted: #94a3b8;
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
		background: var(--bg);
		color: var(--text);
	}
	body { margin: 0; }
	
	nav {
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		padding: 1.5rem 0;
		position: sticky;
		top: 0;
		background: rgba(5, 10, 15, 0.8);
		backdrop-filter: blur(12px);
		z-index: 100;
	}
	.nav-content {
		max-width: 1000px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 2rem;
	}
	.logo-link {
		font-weight: 800;
		font-size: 1.25rem;
		text-decoration: none;
		color: #fff;
		letter-spacing: -0.02em;
	}
	.links { display: flex; gap: 2rem; align-items: center; }
	.links a {
		text-decoration: none;
		color: var(--text-muted);
		font-weight: 500;
		font-size: 0.9rem;
		transition: color 0.2s;
	}
	.links a:hover { color: var(--cyan); }
	
	.nav-button {
		background: var(--cyan);
		color: #050a0f !important;
		padding: 0.6rem 1.2rem;
		border-radius: 8px;
		font-weight: 700 !important;
	}

	footer {
		text-align: center;
		padding: 4rem 0;
		color: var(--text-muted);
		font-size: 0.875rem;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		margin-top: 4rem;
	}

	/* Utility: Electric Text gradient */
	.electric-text {
		background: linear-gradient(to right, var(--cyan), var(--blue));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
</style>
