---
import TechSection from './TechSection.astro';
---

<section class="tech-deep-dive py-16 bg-slate-900 text-white">
  <div class="container mx-auto px-4">
    <h2 class="text-4xl font-bold mb-12 text-center">Impeller Tech: Rudderless Propulsion</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <TechSection 
        title="Vectorized Thrust"
        description="Our proprietary impeller system uses vectorized thrust to achieve precise directional control without traditional rudders, reducing drag and increasing efficiency by up to 30%."
        icon="vector"
      />
      
      <TechSection 
        title="Zero-Drag Hydrodynamics"
        description="By eliminating the rudder, we've achieved a 'clean' hull profile. This allows for smoother laminar flow and significantly reduces the vortex wake commonly associated with marine propulsion."
        icon="hydro"
      />
      
      <TechSection 
        title="Digital Control Logic"
        description="The heart of Fluidity is our propulsive software. It calculates real-time adjustments to impeller RPM and angle, providing unmatched stability and agility in diverse marine conditions."
        icon="cpu"
      />
    </div>
  </div>
</section>
