---
import TechSection from './TechSection.astro';
---

<section class="tech-deep-dive py-16 bg-slate-900 text-white">
  <div class="container mx-auto px-4">
    <h2 class="text-4xl font-bold mb-12 text-center">Impeller Tech: Rudderless Propulsion</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <TechSection 
        title="Snave Impeller Dynamics"
        description="Our 'Snave' impeller is a proprietary, fully-enclosed propulsive system that eliminates external propeller danger while generating high-pressure flow for superior thrust-to-energy ratios."
        icon="vector"
      />
      
      <TechSection 
        title="Rudderless Vectoring"
        description="By employing horizontal nozzle articulation, we achieve 360-degree maneuverability. This eliminates the drag of traditional rudders and enables surgical precision in tight waterways."
        icon="hydro"
      />
      
      <TechSection 
        title="Digital Propulsion Guard"
        description="An integrated software suite monitors impeller RPM and nozzle angle in real-time, preventing hull cavitation and optimizing performance for 'charge on the water' renewable integration."
        icon="cpu"
      />
    </div>
  </div>
</section>
