---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
---

<div id="container">
	<img id="background" src={background.src} alt="" fetchpriority="high" />
	<main>
		<section id="hero">
			<div class="brand-header">
				<img src={astroLogo.src} width="48" height="48" alt="Fluidity Marine" class="logo" />
				<span class="brand-name">Fluidity Marine</span>
			</div>
			
			<h1>
				The Future of <span class="electric-text">Autonomous</span> Marine Systems.
			</h1>
			
			<p class="tagline">
				Engineering fluid intelligence for the next generation of maritime robotics.
			</p>

			<section id="cta-group">
				<a class="button primary crowdfunding" href="/crowdfund">
					Join the Mission
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
				</a>
				<a class="button secondary" href="#mission">View Strategy</a>
			</section>
		</section>
	</main>

	<div id="campaign-alert" class="box">
		<div class="pulse-icon"></div>
		<h2>Crowdfunding Active</h2>
		<p>
			Our Seed Phase is now open. Participate in the future of autonomous marine exploration.
		</p>
		<a href="/crowdfund" class="learn-more">Learn more &rarr;</a>
	</div>
</div>

<style>
	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(100px);
	}

	#container {
		font-family: 'Inter Variable', Inter, Roboto, sans-serif;
		height: 100vh;
		background: #050a0f;
		color: #e2e8f0;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.brand-header {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 24px;
	}

	.brand-name {
		font-weight: 700;
		letter-spacing: -0.02em;
		font-size: 1.25rem;
		color: #fff;
	}

	main {
		max-width: 800px;
		padding: 2rem;
		z-index: 10;
	}

	#hero {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	h1 {
		font-size: clamp(2.5rem, 8vw, 4.5rem);
		font-weight: 800;
		line-height: 1.1;
		margin: 0;
		letter-spacing: -0.04em;
		color: #fff;
	}

	.electric-text {
		background: linear-gradient(to right, #00f2fe 0%, #4facfe 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.tagline {
		font-size: 1.25rem;
		color: #94a3b8;
		margin: 24px 0 40px;
		max-width: 600px;
		line-height: 1.6;
	}

	#cta-group {
		display: flex;
		gap: 16px;
	}

	.button {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 14px 28px;
		border-radius: 12px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.button.primary {
		background: #fff;
		color: #050a0f;
	}

	.button.primary.crowdfunding {
		background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
		color: #fff;
		border: none;
		box-shadow: 0 10px 15px -3px rgba(79, 172, 254, 0.3);
	}

	.button.primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
	}

	.button.secondary {
		border: 1px solid rgba(255, 255, 255, 0.1);
		color: #fff;
		background: rgba(255, 255, 255, 0.03);
	}

	.button.secondary:hover {
		background: rgba(255, 255, 255, 0.08);
	}

	#campaign-alert {
		position: absolute;
		bottom: 32px;
		right: 32px;
		width: 340px;
		background: rgba(15, 23, 42, 0.8);
		border: 1px solid rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(12px);
		padding: 24px;
		border-radius: 20px;
	}

	.pulse-icon {
		width: 12px;
		height: 12px;
		background: #00f2fe;
		border-radius: 50%;
		margin-bottom: 12px;
		box-shadow: 0 0 0 0 rgba(0, 242, 254, 0.4);
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0% { box-shadow: 0 0 0 0 rgba(0, 242, 254, 0.7); }
		70% { box-shadow: 0 0 0 10px rgba(0, 242, 254, 0); }
		100% { box-shadow: 0 0 0 0 rgba(0, 242, 254, 0); }
	}

	h2 {
		font-size: 1.125rem;
		margin: 0 0 8px;
		color: #fff;
	}

	p {
		font-size: 0.875rem;
		color: #94a3b8;
		line-height: 1.5;
		margin-bottom: 16px;
	}

	.learn-more {
		font-size: 0.875rem;
		font-weight: 600;
		color: #00f2fe;
		text-decoration: none;
	}

	@media (max-width: 640px) {
		#campaign-alert {
			position: relative;
			bottom: auto;
			right: auto;
			width: 100%;
			margin-top: 2rem;
		}
		
		#cta-group {
			flex-direction: column;
			width: 100%;
		}
		
		.button {
			justify-content: center;
		}
	}
</style>
