---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Press & Media Kit | Fluidity Marine">
  <main class="page">
    <!-- Hero -->
    <section class="press-hero animate-in">
      <h1 class="page-title">Media Kit</h1>
      <p class="page-subtitle">
        Background information on Fluidity Marine, a division of InnovativeDynamix 
        developing Active Boundary Layer Thrust Vectoring (ABLTV).
      </p>
    </section>

    <!-- Quick Facts -->
    <section class="asset-group animate-in delay-1">
      <h2 class="section-title">Quick Facts</h2>
      <div class="card brand-brief">
        <div class="brand-field">
          <span class="brand-label">Entity</span>
          <span class="brand-value">InnovativeDynamix / Fluidity Marine</span>
        </div>
        <div class="brand-field">
          <span class="brand-label">Technology</span>
          <span class="brand-value">Active Boundary Layer Thrust Vectoring (ABLTV)</span>
        </div>
        <div class="brand-field">
          <span class="brand-label">Description</span>
          <span class="brand-value">A rudderless marine propulsion system using a synchronized array of 7 water jets at the transom, controlled by a 2,000Hz digital control loop.</span>
        </div>
        <div class="brand-field">
          <span class="brand-label">Funding Stage</span>
          <span class="brand-value">Seed Round — $5M</span>
        </div>
        <div class="brand-field">
          <span class="brand-label">CEO</span>
          <span class="brand-value">Aaron Evans</span>
        </div>
        <div class="brand-field">
          <span class="brand-label">Intellectual Property</span>
          <span class="brand-value">5 patent filings</span>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="asset-group animate-in delay-2">
      <h2 class="section-title">About Fluidity Marine</h2>
      <div class="glass-box">
        <p>Fluidity Marine is developing the first rudderless marine propulsion system. The company's core technology, Active Boundary Layer Thrust Vectoring (ABLTV), replaces the mechanical rudder with a synchronized array of 7 water jets mounted flush at the transom. Steering is achieved by modulating thrust across individual jets — eliminating underwater moving parts and parasitic drag from rudder surfaces.</p>
        <p style="margin-top: 1rem;">The company is currently raising a $5M Seed round to fund prototype manufacturing, on-water trials, intellectual property protection, and team expansion. Fluidity Marine is a division of InnovativeDynamix.</p>
      </div>
    </section>

    <!-- Contact -->
    <section class="asset-group animate-in delay-3">
      <h2 class="section-title">Press Contact</h2>
      <div class="glass-box">
        <p>Aaron Evans — CEO / Chief Scientist</p>
        <p><a href="mailto:aaron@fluiditymarine.com" style="color: var(--cyan, #00F0FF);">aaron@fluiditymarine.com</a></p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .press-hero { margin-bottom: 4rem; }

  .asset-group { margin-bottom: 4rem; }

  .brand-brief {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .brand-field {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .brand-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted, #8899b4);
  }

  .brand-value {
    font-size: 1rem;
    color: #fff;
    line-height: 1.5;
  }
</style>
