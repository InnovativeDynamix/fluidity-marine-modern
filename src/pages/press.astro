---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Press | Fluidity Marine">
	<main class="max-w-4xl mx-auto px-6 py-20">
		<h1 class="text-4xl font-extrabold mb-4">Media Kit</h1>
		<p class="text-lg text-slate-400 mb-12">Foundational assets and narrative briefs for the Maritime Paradigm Shift.</p>

		<section class="grid gap-16">
			<div class="asset-group">
				<h2 class="text-2xl font-bold mb-6 text-cyan-400">Brand Synthesis</h2>
				<div class="bg-white/5 p-8 rounded-2xl border border-white/10">
					<p class="mb-4"><strong>Slogan:</strong> Be Part of the Solution, Not the Pollution!</p>
					<p class="mb-4"><strong>Key USP:</strong> Active Boundary Layer Thrust Vectoring (ABLTV). By removing the mechanical rudder, Fluidity Marine increases range and eliminates the primary mechanical failure point of oceanic vessels.</p>
				</div>
			</div>

			<div class="asset-group">
				<h2 class="text-2xl font-bold mb-6 text-cyan-400">Press Assets</h2>
				<ul class="list-disc pl-6 text-slate-400 space-y-4">
					<li><a href="/favicon.svg" class="hover:text-white underline">Vector Logo (SVG)</a></li>
					<li>High-Res Imagery (Coming Soon)</li>
					<li>Technical Whitepaper (Q3 2026)</li>
				</ul>
			</div>
		</section>

		<section class="mt-20 pt-10 border-t border-white/10">
			<h2 class="text-xl font-bold mb-4">Media Contact</h2>
			<p class="text-slate-400">Aaron Evans, CEO<br/>info@fluiditymarine.com</p>
		</section>
	</main>
</Layout>
