---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | InnovativeDynamix & Fluidity Marine">
  <main class="page">
    <!-- Hero -->
    <section class="about-hero animate-in">
      <h1 class="page-title">
        About <span class="electric-text">Fluidity Marine</span>
      </h1>
      <p class="page-subtitle">
        Fluidity Marine is a division of InnovativeDynamix, developing Active Boundary Layer 
        Thrust Vectoring (ABLTV) — a rudderless marine propulsion system currently raising 
        a $5M Seed round.
      </p>
    </section>

    <!-- Entity Cards -->
    <section class="entity-grid animate-in delay-1">
      <div class="card entity-card">
        <div class="entity-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
          </svg>
        </div>
        <h3>InnovativeDynamix</h3>
        <p>Parent R&D entity and IP holding company. Manages the ABLTV patent portfolio and venture development.</p>
      </div>

      <div class="card entity-card">
        <div class="entity-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
          </svg>
        </div>
        <h3>Fluidity Marine</h3>
        <p>Flagship vessel brand. Developing the first ABLTV-equipped production vessel. Currently raising $5M Seed round on Wefunder.</p>
        <a href="/investors" class="entity-link">Investor Information →</a>
      </div>
    </section>

    <!-- Team -->
    <hr class="divider" />
    <section class="team-section animate-in delay-2">
      <h2 class="section-title">Team</h2>
      <p class="section-subtitle">The people behind Fluidity Marine.</p>
      <div class="card-grid">
        <div class="card">
          <h3>Aaron Evans</h3>
          <p style="color: var(--text-muted, #8899b4); margin-bottom: 0.5rem; font-size: 0.9rem;">CEO / Chief Scientist</p>
          <p style="color: var(--text-muted, #8899b4); line-height: 1.7; margin: 0;">Founder of InnovativeDynamix and inventor of the ABLTV platform.</p>
        </div>
      </div>
    </section>

    <!-- Portfolio -->
    <hr class="divider" />
    <section class="portfolio-section animate-in delay-2">
      <h2 class="section-title">Portfolio Entities</h2>
      <div class="card-grid" style="grid-template-columns: repeat(3, 1fr);">
        <div class="card" style="text-align: center; padding: 2rem;">
          <h3 style="font-size: 1rem;">InnovativeDynamix</h3>
          <p style="color: var(--text-muted, #8899b4); font-size: 0.85rem; margin: 0;">Parent R&D, IP holding</p>
        </div>
        <div class="card" style="text-align: center; padding: 2rem;">
          <h3 style="font-size: 1rem;">Fluidity Marine</h3>
          <p style="color: var(--text-muted, #8899b4); font-size: 0.85rem; margin: 0;">Vessel brand, $5M Seed</p>
        </div>
        <div class="card" style="text-align: center; padding: 2rem;">
          <h3 style="font-size: 1rem;">The Floating Bar</h3>
          <p style="color: var(--text-muted, #8899b4); font-size: 0.85rem; margin: 0;">Lifestyle / community brand</p>
        </div>
      </div>
    </section>
  </main>
</Layout>
