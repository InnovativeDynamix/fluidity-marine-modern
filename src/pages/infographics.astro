---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Technology Infographics | Fluidity Marine">
  <main class="infographics-page">
    
    <!-- ════════════════════════════════════════════════════════ -->
    <!-- SECTION 1: HERO                                         -->
    <!-- ════════════════════════════════════════════════════════ -->
    <section class="ig-hero animate-in">
      <h1 class="page-title">
        Technology<br />
        <span class="electric-text">Infographics</span>
      </h1>
      <p class="page-subtitle">
        Visual guides to Active Boundary Layer Thrust Vectoring — 
        how ABLTV replaces mechanical rudders with a synchronized 
        array of water jets.
      </p>
    </section>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- SECTION 2: ABLTV CONCEPT                                 -->
    <!-- ════════════════════════════════════════════════════════ -->
    <section class="ig-section animate-in delay-1">
      <h2 class="section-title">ABLTV Concept</h2>
      <p class="section-subtitle">Replacing the mechanical rudder with fluid intelligence.</p>

      <div class="ig-concept-grid">
        <div class="card ig-concept-card">
          <h3>7-Jet Array</h3>
          <p>A synchronized array of water jets mounted flush at the transom. Each jet modulates independently to control vessel direction — no protruding rudder required.</p>
        </div>

        <div class="card ig-concept-card">
          <h3>Differential Steering</h3>
          <p>Turning is achieved by varying thrust across the jet array. The resulting pressure differential rotates the vessel — controlled entirely in software.</p>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- SECTION 3: THE DIAGRAM                                   -->
    <!-- ════════════════════════════════════════════════════════ -->
    <section class="ig-section animate-in delay-2">
      <h2 class="section-title">System Diagram</h2>
      <p class="section-subtitle">A clean hull profile with no underwater appendages.</p>

      <div class="ig-diagram-container">
        <svg viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="ig-diagram">
          <!-- Hull shape -->
          <path d="M80 180 C200 120, 350 100, 500 100 C620 100, 700 120, 750 160 L780 200 L80 200 Z" 
                fill="url(#hullGrad2)" stroke="rgba(0,240,255,0.3)" stroke-width="1"/>
          
          <!-- Boundary layer -->
          <path d="M60 210 C200 150, 350 130, 500 130 C620 130, 710 150, 770 190" 
                stroke="rgba(0,240,255,0.2)" stroke-width="1.5" stroke-dasharray="6,4" fill="none"/>
          <text x="30" y="155" fill="rgba(148,163,184,0.5)" font-size="11" font-family="Inter">Boundary Layer</text>

          <!-- Waterline -->
          <line x1="40" y1="195" x2="780" y2="195" stroke="rgba(0,240,255,0.08)" stroke-width="1"/>

          <!-- 7 Thrust nodes -->
          <circle cx="700" cy="155" r="11" fill="rgba(0,240,255,0.15)" stroke="#00F0FF" stroke-width="1.5"/>
          <text x="696" y="159" fill="#00F0FF" font-size="9" font-weight="700" font-family="Inter">1</text>
          <circle cx="718" cy="160" r="11" fill="rgba(0,240,255,0.15)" stroke="#00F0FF" stroke-width="1.5"/>
          <text x="714" y="164" fill="#00F0FF" font-size="9" font-weight="700" font-family="Inter">2</text>
          <circle cx="733" cy="168" r="11" fill="rgba(0,240,255,0.15)" stroke="#00F0FF" stroke-width="1.5"/>
          <text x="729" y="172" fill="#00F0FF" font-size="9" font-weight="700" font-family="Inter">3</text>
          <circle cx="743" cy="178" r="11" fill="rgba(255,184,0,0.2)" stroke="#FFB800" stroke-width="1.5"/>
          <text x="739" y="182" fill="#FFB800" font-size="9" font-weight="700" font-family="Inter">4</text>
          <circle cx="748" cy="188" r="11" fill="rgba(0,240,255,0.15)" stroke="#00F0FF" stroke-width="1.5"/>
          <text x="744" y="192" fill="#00F0FF" font-size="9" font-weight="700" font-family="Inter">5</text>
          <circle cx="746" cy="198" r="11" fill="rgba(0,240,255,0.15)" stroke="#00F0FF" stroke-width="1.5"/>
          <text x="742" y="202" fill="#00F0FF" font-size="9" font-weight="700" font-family="Inter">6</text>
          <circle cx="738" cy="208" r="11" fill="rgba(0,240,255,0.15)" stroke="#00F0FF" stroke-width="1.5"/>
          <text x="734" y="212" fill="#00F0FF" font-size="9" font-weight="700" font-family="Inter">7</text>

          <text x="120" y="150" fill="rgba(255,255,255,0.4)" font-size="12" font-family="Inter">Clean Hull Profile</text>
          <text x="665" y="120" fill="#00F0FF" font-size="13" font-weight="700" font-family="Inter">7× Thrust Array</text>

          <defs>
            <linearGradient id="hullGrad2" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="rgba(15,23,42,0.6)"/>
              <stop offset="50%" stop-color="rgba(30,41,59,0.4)"/>
              <stop offset="100%" stop-color="rgba(15,23,42,0.6)"/>
            </linearGradient>
          </defs>
        </svg>
      </div>
    </section>
  </main>
</Layout>

<style>
  .ig-hero { margin-bottom: 4rem; }

  .ig-section { margin-bottom: 5rem; }

  .ig-concept-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .ig-concept-card { padding: 2rem; }

  .ig-concept-card h3 {
    font-size: 1.2rem;
    color: #fff;
    margin: 0 0 1rem;
  }

  .ig-concept-card p {
    color: var(--text-muted, #8899b4);
    line-height: 1.7;
    margin: 0;
  }

  .ig-diagram-container {
    background: var(--bg-card, rgba(15,31,58,0.5));
    border: 1px solid var(--border, rgba(13,194,176,0.12));
    border-radius: var(--radius-xl, 20px);
    padding: 2rem;
    overflow: hidden;
  }

  .ig-diagram {
    width: 100%;
    height: auto;
  }

  @media (max-width: 768px) {
    .ig-concept-grid { grid-template-columns: 1fr; }
  }
</style>
