---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Fluidity Marine | Clean Electric Propulsion">
  <!-- Animated Background -->
  <div class="bg-container">
    <div class="bg-gradient-overlay"></div>
    <div class="particle-field" id="particles"></div>
    <div class="vessel-bg-overlay"></div>
  </div>

  <main class="page" style="border:none; display: flex; flex-direction: column; padding-top: 2rem; padding-bottom: 2rem;">

    <!-- ─── 1. HERO ─── -->
    <div class="hero-content">
      <div class="badge animate-in">
        <span class="badge-dot"></span>
        Seed Round Open on Wefunder
      </div>

      <h1 class="hero-title animate-in delay-1">
        Clean <span class="electric-text">Electric</span> Propulsion<br />
        <span class="hero-subline">for our Seas.</span>
      </h1>

      <p class="hero-tagline animate-in delay-2">
        Replacing toxic outboard motors with modular, 3D-printed fluid intelligence.
        The first rudderless marine propulsion system — powered by ABLTV.
      </p>

      <div class="hero-actions animate-in delay-3">
        <a href="https://wefunder.com/fluidity" class="button button-primary button-lg" target="_blank" rel="noopener">
          Invest on Wefunder
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/technology" class="button button-secondary button-lg">
          Explore the Technology
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 17 16 12 7 7"/></svg>
        </a>
        <a href="/tools/simulator.html" class="button button-secondary button-lg">
          Launch Simulator
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
        </a>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="stats-bar animate-in delay-4">
      <div class="stat-item">
        <span class="stat-value">7</span>
        <span class="stat-label">Thrust Nodes</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">100Hz</span>
        <span class="stat-label">Control Loop</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">Zero</span>
        <span class="stat-label">Mechanical Drag</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">Patent</span>
        <span class="stat-label">Pending</span>
      </div>
    </div>

    <!-- ─── 2. WHO WE ARE ─── -->
    <hr class="divider" />
    <section class="who-section animate-in delay-1">
      <h2 class="section-title">Who Are We?</h2>
      <p class="section-subtitle">Innovators at the intersection of fluid dynamics and digital control.</p>
      <div class="who-layout">
        <div class="who-text">
          <p>
            At Fluidity Marine, we are innovators and thought leaders in the maritime industry, driven by our passion for environmental responsibility and technological advancements. Our initial focus is on cost-effective electric boat motors featuring a novel impeller design and rudderless control — replacing existing fossil fuel outboard motors to minimize ecological damage and maximize marine safety.
          </p>
        </div>
        <div class="card about-card">
          <div class="about-card-header">
            <div class="about-avatar">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <div>
              <h3>Aaron Evans</h3>
              <span class="about-role">CEO / Chief Scientist</span>
            </div>
          </div>
          <p class="about-bio">
            Founder and driving force behind InnovativeDynamix and the ABLTV platform. Leading the transition from laboratory breakthroughs to global maritime infrastructure.
          </p>
          <div class="about-tags">
            <span class="about-tag">InnovativeDynamix</span>
            <span class="about-tag">ABLTV</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── VESSEL IMAGE ─── -->
    <section class="image-break animate-in delay-2">
      <div class="image-break-container">
        <img src="/images/beyond-hulls.png" alt="Fluidity Marine ecosystem concept" class="full-width-image" />
        <div class="image-caption">Beyond the Hull — The complete Fluidity Marine ecosystem: electric vessels, Floating Bar lifestyle anchor, and sustainable maritime infrastructure</div>
      </div>
    </section>

    <!-- ─── 3. MISSION ─── -->
    <hr class="divider" />
    <section class="mission-section animate-in delay-2">
      <h2 class="section-title">What is our Mission?</h2>
      <p class="section-subtitle">Three pillars guide everything we build.</p>
      <div class="mission-grid">
        <div class="card mission-pillar">
          <div class="pillar-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s-8-4-8-10V5l8-3 8 3v7c0 6-8 10-8 10z"/>
              <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
          <h3>Environmental Stewardship</h3>
          <p>Eliminate pollution from traditional propulsion. Protect marine ecosystems via electric impeller motors — zero emissions, no fuel, oil, or CO₂.</p>
        </div>
        <div class="card mission-pillar">
          <div class="pillar-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="8" height="8" rx="1" ry="1"/>
              <rect x="14" y="2" width="8" height="8" rx="1" ry="1"/>
              <rect x="2" y="14" width="8" height="8" rx="1" ry="1"/>
              <rect x="14" y="14" width="8" height="8" rx="1" ry="1"/>
            </svg>
          </div>
          <h3>Innovation &amp; Advancement</h3>
          <p>Groundbreaking impeller system delivering superior performance, efficiency, and safety. Continuous R&amp;D to set new industry standards for marine propulsion.</p>
        </div>
        <div class="card mission-pillar">
          <div class="pillar-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 100 4h4a2 2 0 110 4H8"/><path d="M12 18V6"/>
            </svg>
          </div>
          <h3>Accessibility &amp; Affordability</h3>
          <p>Cost-effective solutions to accelerate global adoption. Transition to electric impeller motors is within reach for boat owners and operators across every sector.</p>
        </div>
      </div>
    </section>

    <!-- ─── 4. TECHNOLOGY FEATURES ─── -->
    <hr class="divider" />
    <section class="features-section animate-in delay-3">
      <h2 class="section-title">A Look At Our Initial Ideas</h2>
      <p class="section-subtitle">Eight innovations that define the next generation of marine propulsion.</p>
      <div class="features-grid">
        <div class="card feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
            </svg>
          </div>
          <h3>Electric Brushless Motors</h3>
          <p>No toxic pollutants; clean, silent operation</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
            </svg>
          </div>
          <h3>Novel Impeller Design</h3>
          <p>All-enclosed moving parts; no exposed propeller</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>
            </svg>
          </div>
          <h3>Modular Components</h3>
          <p>Fully customizable solution per user needs</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3>Rudderless Steering</h3>
          <p>Vector thrust control eliminates traditional rudder</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </div>
          <h3>Integrated Renewables</h3>
          <p>Charge on the water via solar/wind integration</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>
            </svg>
          </div>
          <h3>Advanced Controls</h3>
          <p>Mobile app &amp; manual piloting options</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5"/><line x1="12" y1="22" x2="12" y2="15.5"/><polyline points="22 8.5 12 15.5 2 8.5"/>
            </svg>
          </div>
          <h3>Manufactured On-Demand</h3>
          <p>Custom 3D-printed to spec</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 14.899A7 7 0 119.9 4c.22 0 .44.01.66.04"/><path d="M14.9 9.9A7 7 0 1116 20"/><path d="M12 13a3 3 0 100-6 3 3 0 000 6z"/>
            </svg>
          </div>
          <h3>Horizontal Nozzle Design</h3>
          <p>Optimized pressure surface for maximum thrust</p>
        </div>
      </div>
    </section>

    <!-- ─── ABLTV DIAGRAM ─── -->
    <section class="image-break animate-in delay-3">
      <div class="image-break-container">
        <img src="/images/propulsion-tech.png" alt="ABLTV propulsion system cross-section" class="full-width-image" />
        <div class="image-caption">Active Boundary Layer Thrust Vectoring — 7-node transom cutaway showing jet modulation at the hydrodynamic interface</div>
      </div>
    </section>

    <!-- ─── 5. BENEFITS ─── -->
    <hr class="divider" />
    <section class="benefits-section animate-in delay-4">
      <h2 class="section-title">The Immediate Benefits</h2>
      <p class="section-subtitle">Tangible advantages that make a difference from day one.</p>
      <div class="benefits-grid">
        <div class="card benefit-card">
          <div class="benefit-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s-8-4-8-10V5l8-3 8 3v7c0 6-8 10-8 10z"/><polyline points="9 12 11 14 15 10"/>
            </svg>
          </div>
          <h3>Eliminate Pollution</h3>
          <p>No fuel, oil, or CO₂ emissions. Zero environmental footprint.</p>
        </div>
        <div class="card benefit-card">
          <div class="benefit-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
            </svg>
          </div>
          <h3>Zero Prop/Rudder Damage</h3>
          <p>Protects aquatic flora and fauna. No more snagged props.</p>
        </div>
        <div class="card benefit-card">
          <div class="benefit-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/>
            </svg>
          </div>
          <h3>Minimize Noise Impacts</h3>
          <p>Silent electric operation reduces ecological stress on marine life.</p>
        </div>
        <div class="card benefit-card">
          <div class="benefit-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <h3>Better Performance</h3>
          <p>More thrust with less energy. Superior efficiency at every RPM.</p>
        </div>
      </div>
    </section>

    <!-- ─── EXPLORE OUR SITE ─── -->
    <hr class="divider" />
    <section class="nav-cards-section animate-in delay-4">
      <h2 class="section-title">Explore Our Site</h2>
      <p class="section-subtitle">Dive deeper into the technology, venture, and mission.</p>

      <div class="nav-card-grid">
        <a href="/technology" class="nav-card" style="position:relative; overflow:hidden;">
          <!-- Large background SVG -->
          <div class="nav-card-bg" aria-hidden="true">
            <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;opacity:0.06;">
              <!-- Hull cross-section -->
              <path d="M50 200 C120 160, 200 140, 300 140 C350 140, 380 155, 400 180 L400 280 L50 280 Z" fill="var(--ocean)" stroke="var(--ocean)" stroke-width="1"/>
              <!-- Water line -->
              <path d="M0 220 C80 215, 160 210, 250 215 C320 218, 380 225, 400 230" stroke="var(--ocean)" stroke-width="1.5" fill="none" opacity="0.5"/>
              <!-- Thrust nodes at transom -->
              <circle cx="370" cy="190" r="10" fill="none" stroke="var(--ocean)" stroke-width="2"/>
              <circle cx="385" cy="200" r="10" fill="none" stroke="var(--ocean)" stroke-width="2"/>
              <circle cx="395" cy="215" r="10" fill="none" stroke="var(--ocean)" stroke-width="2"/>
              <circle cx="398" cy="230" r="10" fill="none" stroke="var(--ocean)" stroke-width="2"/>
              <!-- Jet streams -->
              <path d="M395 200 C420 180, 440 160, 450 150" stroke="var(--ocean)" stroke-width="3" stroke-linecap="round" opacity="0.6" fill="none"/>
              <path d="M398 215 C430 205, 445 190, 460 180" stroke="var(--electric)" stroke-width="2.5" stroke-linecap="round" opacity="0.4" fill="none"/>
              <path d="M398 230 C430 225, 450 215, 465 205" stroke="var(--ocean)" stroke-width="2" stroke-linecap="round" opacity="0.3" fill="none"/>
              <!-- Flow arrows -->
              <path d="M100 200 L250 200" stroke="var(--ocean)" stroke-width="1" stroke-dasharray="4,4" fill="none" opacity="0.3"/>
              <path d="M120 160 L220 160" stroke="var(--ocean)" stroke-width="1" stroke-dasharray="4,4" fill="none" opacity="0.3"/>
              <!-- Grid dots -->
              <circle cx="80" cy="120" r="2" fill="var(--ocean)" opacity="0.3"/>
              <circle cx="320" cy="100" r="2" fill="var(--ocean)" opacity="0.3"/>
              <circle cx="150" cy="100" r="1.5" fill="var(--ocean)" opacity="0.2"/>
              <circle cx="280" cy="120" r="1.5" fill="var(--ocean)" opacity="0.2"/>
            </svg>
          </div>
          <div class="nav-card-content">
            <h3>Technology</h3>
            <p>ABLTV deep dive — how rudderless thrust vectoring works</p>
          </div>
        </a>
        <a href="/infographics" class="nav-card" style="position:relative; overflow:hidden;">
          <div class="nav-card-bg" aria-hidden="true">
            <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;opacity:0.06;">
              <!-- Bar chart -->
              <rect x="60" y="220" width="40" height="120" rx="4" fill="var(--ocean)" opacity="0.5"/>
              <rect x="120" y="160" width="40" height="180" rx="4" fill="var(--ocean)" opacity="0.4"/>
              <rect x="180" y="120" width="40" height="220" rx="4" fill="var(--electric)" opacity="0.5"/>
              <rect x="240" y="90" width="40" height="250" rx="4" fill="var(--ocean)" opacity="0.4"/>
              <rect x="300" y="140" width="40" height="200" rx="4" fill="var(--ocean)" opacity="0.3"/>
              <!-- Wave line -->
              <path d="M20 350 C60 330, 100 370, 140 350 C180 330, 220 370, 260 350 C300 330, 340 370, 380 350" stroke="var(--ocean)" stroke-width="2" fill="none" opacity="0.4"/>
              <!-- Data points -->
              <circle cx="90" cy="230" r="4" fill="var(--ocean)" opacity="0.5"/>
              <circle cx="200" cy="130" r="5" fill="var(--electric)" opacity="0.6"/>
              <circle cx="310" cy="100" r="3" fill="var(--ocean)" opacity="0.4"/>
              <!-- Grid lines -->
              <line x1="40" y1="80" x2="380" y2="80" stroke="var(--ocean)" stroke-width="0.5" opacity="0.15"/>
              <line x1="40" y1="160" x2="380" y2="160" stroke="var(--ocean)" stroke-width="0.5" opacity="0.15"/>
              <line x1="40" y1="240" x2="380" y2="240" stroke="var(--ocean)" stroke-width="0.5" opacity="0.15"/>
            </svg>
          </div>
          <div class="nav-card-content">
            <h3>Infographics</h3>
            <p>Visual diagrams and technical illustrations</p>
          </div>
        </a>
        <a href="/about" class="nav-card" style="position:relative; overflow:hidden;">
          <div class="nav-card-bg" aria-hidden="true">
            <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;opacity:0.06;">
              <!-- Compass rose -->
              <circle cx="200" cy="200" r="120" stroke="var(--ocean)" stroke-width="1.5" fill="none" opacity="0.4"/>
              <circle cx="200" cy="200" r="80" stroke="var(--ocean)" stroke-width="1" fill="none" opacity="0.3"/>
              <!-- Cardinal points -->
              <polygon points="200,60 195,120 205,120" fill="var(--ocean)" opacity="0.5"/>
              <polygon points="200,340 195,280 205,280" fill="var(--ocean)" opacity="0.3"/>
              <polygon points="60,200 120,195 120,205" fill="var(--ocean)" opacity="0.3"/>
              <polygon points="340,200 280,195 280,205" fill="var(--ocean)" opacity="0.3"/>
              <!-- Venture markers -->
              <circle cx="200" cy="200" r="8" fill="var(--gold)" opacity="0.5"/>
              <text x="170" y="150" fill="var(--gold)" font-size="10" opacity="0.5" font-family="Inter">Fluidity Marine</text>
              <circle cx="150" cy="140" r="4" fill="var(--electric)" opacity="0.4"/>
              <circle cx="260" cy="150" r="4" fill="var(--electric)" opacity="0.4"/>
              <circle cx="190" cy="270" r="4" fill="var(--electric)" opacity="0.4"/>
              <!-- Wave rings -->
              <circle cx="200" cy="200" r="140" stroke="var(--ocean)" stroke-width="0.5" opacity="0.15"/>
              <circle cx="200" cy="200" r="160" stroke="var(--ocean)" stroke-width="0.5" opacity="0.1"/>
            </svg>
          </div>
          <div class="nav-card-content">
            <h3>About</h3>
            <p>The venture portfolio: Fluidity Marine, Floating Bar, ZumZ</p>
          </div>
        </a>
        <a href="/investors" class="nav-card" style="position:relative; overflow:hidden;">
          <div class="nav-card-bg" aria-hidden="true">
            <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;opacity:0.06;">
              <!-- Growth chart -->
              <path d="M40 340 L80 320 L120 280 L160 260 L200 200 L240 160 L280 100 L320 80 L360 60" stroke="var(--ocean)" stroke-width="3" stroke-linecap="round" fill="none"/>
              <!-- Area under curve -->
              <path d="M40 340 L80 320 L120 280 L160 260 L200 200 L240 160 L280 100 L320 80 L360 60 L360 340 Z" fill="url(#investGrad)" opacity="0.3"/>
              <!-- Grid -->
              <line x1="40" y1="100" x2="360" y2="100" stroke="var(--ocean)" stroke-width="0.5" opacity="0.15"/>
              <line x1="40" y1="180" x2="360" y2="180" stroke="var(--ocean)" stroke-width="0.5" opacity="0.15"/>
