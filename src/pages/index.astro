---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Fluidity Marine | Rudderless Marine Propulsion">
  <!-- Animated Background -->
  <div class="bg-container">
    <div class="bg-gradient-overlay"></div>
    <div class="particle-field" id="particles"></div>
    <div class="vessel-bg-overlay"></div>
  </div>

  <main class="page" style="border:none; display: flex; flex-direction: column; padding-top: 2rem; padding-bottom: 2rem;">

    <!-- ─── 1. HERO ─── -->
    <div class="hero-content">
      <h1 class="hero-title animate-in delay-1">
        <span class="electric-text">Rudderless</span> Propulsion<br />
        <span class="hero-subline">for Marine Vessels.</span>
      </h1>

      <p class="hero-tagline animate-in delay-2">
        Fluidity Marine is developing Active Boundary Layer Thrust Vectoring (ABLTV):
        a synchronized array of water jets that replaces the mechanical rudder.
      </p>

      <div class="hero-actions animate-in delay-3">
        <a href="/technology" class="button button-secondary button-lg">
          How It Works
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 17 16 12 7 7"/></svg>
        </a>
        <a href="/investors" class="button button-primary button-lg">
          Investor Information
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>

    <!-- ─── ABOUT ─── -->
    <hr class="divider" />
    <section class="who-section animate-in delay-2">
      <h2 class="section-title">What Is Fluidity Marine?</h2>
      <p class="section-subtitle">A venture developing the first rudderless marine propulsion system.</p>
      <div class="who-layout">
        <div class="who-text">
          <p>
            Fluidity Marine is a division of <strong>InnovativeDynamix</strong>, an R&D company 
            focused on marine propulsion technology. Our core technology, <strong>Active Boundary 
            Layer Thrust Vectoring (ABLTV)</strong>, uses a synchronized array of water jets mounted 
            at the transom to steer vessels — eliminating the mechanical rudder entirely.
          </p>
          <p>
            We are currently raising a <strong>$5M Seed round</strong> to fund prototype manufacturing, 
            sea trials, and team expansion.
          </p>
        </div>
        <div class="card about-card">
          <div class="about-card-header">
            <div class="about-avatar">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <div>
              <h3>Aaron Evans</h3>
              <span class="about-role">CEO / Chief Scientist</span>
            </div>
          </div>
          <p class="about-bio">
            Founder of InnovativeDynamix and inventor of the ABLTV platform.
          </p>
          <div class="about-tags">
            <span class="about-tag">InnovativeDynamix</span>
            <span class="about-tag">ABLTV</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── EXPLORE ─── -->
    <hr class="divider" />
    <section class="nav-cards-section animate-in delay-3">
      <h2 class="section-title">Explore</h2>
      <p class="section-subtitle">Learn more about the technology, venture, and team.</p>

      <div class="nav-card-grid">
        <a href="/technology" class="nav-card" style="position:relative; overflow:hidden;">
          <div class="nav-card-bg" aria-hidden="true">
            <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;opacity:0.06;">
              <path d="M50 200 C120 160, 200 140, 300 140 C350 140, 380 155, 400 180 L400 280 L50 280 Z" fill="var(--cyan)" stroke="var(--cyan)" stroke-width="1"/>
              <path d="M0 220 C80 215, 160 210, 250 215 C320 218, 380 225, 400 230" stroke="var(--cyan)" stroke-width="1.5" fill="none" opacity="0.5"/>
              <circle cx="370" cy="190" r="10" fill="none" stroke="var(--cyan)" stroke-width="2"/>
              <circle cx="385" cy="200" r="10" fill="none" stroke="var(--cyan)" stroke-width="2"/>
              <circle cx="395" cy="215" r="10" fill="none" stroke="var(--cyan)" stroke-width="2"/>
              <circle cx="398" cy="230" r="10" fill="none" stroke="var(--cyan)" stroke-width="2"/>
              <path d="M395 200 C420 180, 440 160, 450 150" stroke="var(--cyan)" stroke-width="3" stroke-linecap="round" opacity="0.6" fill="none"/>
              <path d="M398 215 C430 205, 445 190, 460 180" stroke="var(--cyan)" stroke-width="2.5" stroke-linecap="round" opacity="0.4" fill="none"/>
            </svg>
          </div>
          <div class="nav-card-content">
            <h3>Technology</h3>
            <p>How ABLTV works — the physics of boundary layer thrust vectoring</p>
          </div>
        </a>
        <a href="/investors" class="nav-card" style="position:relative; overflow:hidden;">
          <div class="nav-card-bg" aria-hidden="true">
            <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;opacity:0.06;">
              <path d="M40 340 L80 320 L120 280 L160 260 L200 200 L240 160 L280 100 L320 80 L360 60" stroke="var(--cyan)" stroke-width="3" stroke-linecap="round" fill="none"/>
              <line x1="40" y1="100" x2="360" y2="100" stroke="var(--cyan)" stroke-width="0.5" opacity="0.15"/>
              <line x1="40" y1="180" x2="360" y2="180" stroke="var(--cyan)" stroke-width="0.5" opacity="0.15"/>
              <line x1="40" y1="260" x2="360" y2="260" stroke="var(--cyan)" stroke-width="0.5" opacity="0.15"/>
            </svg>
          </div>
          <div class="nav-card-content">
            <h3>Investors</h3>
            <p>$5M seed round — open for qualified investors</p>
          </div>
        </a>
        <a href="/about" class="nav-card" style="position:relative; overflow:hidden;">
          <div class="nav-card-bg" aria-hidden="true">
            <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;opacity:0.06;">
              <circle cx="200" cy="200" r="120" stroke="var(--cyan)" stroke-width="1.5" fill="none" opacity="0.4"/>
              <polygon points="200,60 195,120 205,120" fill="var(--cyan)" opacity="0.5"/>
              <polygon points="200,340 195,280 205,280" fill="var(--cyan)" opacity="0.3"/>
              <polygon points="60,200 120,195 120,205" fill="var(--cyan)" opacity="0.3"/>
              <polygon points="340,200 280,195 280,205" fill="var(--cyan)" opacity="0.3"/>
              <circle cx="200" cy="200" r="8" fill="var(--amber)" opacity="0.5"/>
            </svg>
          </div>
          <div class="nav-card-content">
            <h3>About</h3>
            <p>The venture portfolio: Fluidity Marine, InnovativeDynamix, and The Floating Bar</p>
          </div>
        </a>
        <a href="/contact" class="nav-card" style="position:relative; overflow:hidden;">
          <div class="nav-card-bg" aria-hidden="true">
            <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;opacity:0.06;">
              <path d="M200 60 C145 60 100 105 100 160 C100 240 200 340 200 340 C200 340 300 240 300 160 C300 105 255 60 200 60 Z" fill="none" stroke="var(--amber)" stroke-width="2"/>
              <circle cx="200" cy="160" r="25" fill="none" stroke="var(--amber)" stroke-width="1.5" opacity="0.5"/>
              <rect x="60" y="240" width="120" height="80" rx="8" fill="none" stroke="var(--cyan)" stroke-width="1.5" opacity="0.4"/>
            </svg>
          </div>
          <div class="nav-card-content">
            <h3>Contact</h3>
            <p>Get in touch with the team</p>
          </div>
        </a>
      </div>
    </section>

    <!-- ─── PORTFOLIO ─── -->
    <hr class="divider" />
    <section class="audience-section animate-in delay-4">
      <h2 class="section-title">Portfolio</h2>
      <p class="section-subtitle">Entities within the InnovativeDynamix group.</p>
      <div class="audience-grid">
        <div class="card audience-card">
          <div class="audience-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>InnovativeDynamix</h3>
          <p>Parent R&D entity and IP holding company</p>
        </div>
        <div class="card audience-card">
          <div class="audience-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <h3>Fluidity Marine</h3>
          <p>Flagship vessel brand — ABLTV-equipped, raising $5M Seed</p>
        </div>
        <div class="card audience-card">
          <div class="audience-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3>The Floating Bar</h3>
          <p>Lifestyle and community-facing brand within the group</p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ─── Hero ─── */
  .hero-content {
    max-width: 800px;
    margin: 2rem auto 4rem;
    text-align: center;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin: 0 0 1.5rem;
    color: #fff;
    letter-spacing: -0.03em;
  }

  .hero-subline {
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    font-weight: 400;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .hero-tagline {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 680px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0, 240, 255, 0.08);
    border: 1px solid rgba(0, 240, 255, 0.15);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--cyan);
    margin-bottom: 2rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cyan);
    animation: pulse-dot 2s ease infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ─── About ─── */
  .who-section { margin-bottom: 5rem; }

  .who-layout {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .who-text p {
    color: var(--text-muted);
    line-height: 1.8;
    margin: 0 0 1rem;
    font-size: 1rem;
  }

  .about-card { padding: 1.5rem; }

  .about-card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .about-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(0, 240, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--cyan);
    flex-shrink: 0;
  }

  .about-card-header h3 {
    font-size: 1.1rem;
    color: #fff;
    margin: 0;
  }

  .about-role {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .about-bio {
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0 0 1rem;
    font-size: 0.9rem;
  }

  .about-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .about-tag {
    font-size: 0.75rem;
    background: rgba(0, 240, 255, 0.06);
    border: 1px solid rgba(0, 240, 255, 0.1);
    padding: 0.2rem 0.7rem;
    border-radius: 100px;
    color: var(--cyan);
  }

  /* ─── Nav Cards ─── */
  .nav-cards-section { margin-bottom: 5rem; }

  .nav-card-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .nav-card {
    padding: 2rem;
    border-radius: var(--radius-xl, 20px);
    text-decoration: none;
    background: var(--bg-card, rgba(10,22,40,0.5));
    border: 1px solid var(--border, rgba(13,194,176,0.12));
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    min-height: 180px;
  }

  .nav-card:hover {
    border-color: rgba(0, 240, 255, 0.2);
    transform: translateY(-2px);
    background: rgba(255,255,255,0.05);
  }

  .nav-card-content {
    position: relative;
    z-index: 1;
    margin-top: auto;
  }

  .nav-card-content h3 {
    font-size: 1.1rem;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .nav-card-content p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .nav-card-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* ─── Portfolio ─── */
  .audience-section { margin-bottom: 3rem; }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .audience-card {
    padding: 2rem;
    text-align: center;
  }

  .audience-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(0, 240, 255, 0.06);
    color: var(--cyan);
    margin-bottom: 1rem;
  }

  .audience-card h3 {
    font-size: 1rem;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .audience-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .who-layout { grid-template-columns: 1fr; }
    .nav-card-grid { grid-template-columns: 1fr 1fr; }
    .audience-grid { grid-template-columns: 1fr; }
    .hero-actions { flex-direction: column; align-items: center; }
  }
</style>
