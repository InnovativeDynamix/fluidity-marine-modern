---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home | Fluidity Marine">
	<main>
		<section id="hero">
			<h1>Clean <span class="electric-text">Electric</span> Propulsion for our Seas.</h1>
			<p class="tagline">Replacing toxic outboard motors with modular, 3D-printed fluid intelligence.</p>
			
			<div class="cta-group">
				<a href="https://wefunder.com/fluidity" class="button primary">Join the Mission</a>
				<a href="/technology" class="button secondary">View Strategy</a>
			</div>
		</section>

		<div id="campaign-alert" class="box">
			<div class="pulse-icon"></div>
			<h2>Crowdfunding Active</h2>
			<p>Participate in the future of clean, electric marine propulsion.</p>
			<a href="https://wefunder.com/fluidity" class="learn-more">Invest on Wefunder &rarr;</a>
		</div>
	</main>
</Layout>

<style>
	main {
		max-width: 1000px;
		margin: 0 auto;
		padding: 8rem 2rem;
		min-height: 80vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	#hero { max-width: 700px; }
	h1 { font-size: clamp(3rem, 10vw, 5rem); font-weight: 900; line-height: 1; margin: 0 0 2rem; color: #fff; }
	.tagline { font-size: 1.25rem; color: #94a3b8; margin-bottom: 3rem; }
	
	.cta-group { display: flex; gap: 1rem; }
	.button { padding: 1rem 2rem; border-radius: 12px; text-decoration: none; font-weight: 700; transition: all 0.2s; }
	.button.primary { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: #050a0f; box-shadow: 0 10px 20px rgba(0, 242, 254, 0.2); }
	.button.secondary { border: 1px solid rgba(255,255,255,0.1); color: #fff; }
	.button:hover { transform: translateY(-2px); filter: brightness(1.1); }

	#campaign-alert {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		width: 320px;
		background: rgba(15, 23, 42, 0.9);
		backdrop-filter: blur(12px);
		border: 1px solid rgba(255, 255, 255, 0.1);
		padding: 2rem;
		border-radius: 20px;
	}
	.pulse-icon { width: 10px; height: 10px; background: #00f2fe; border-radius: 50%; box-shadow: 0 0 10px #00f2fe; margin-bottom: 1rem; animation: pulse 2s infinite; }
	@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }
	h2 { font-size: 1.25rem; color: #fff; margin: 0 0 0.5rem; }
	p { font-size: 0.9rem; color: #94a3b8; margin-bottom: 1.5rem; }
	.learn-more { color: #00f2fe; text-decoration: none; font-weight: 700; font-size: 0.9rem; }
</style>
