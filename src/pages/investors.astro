---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Investors | Fluidity Marine — $5M Seed Round">
  <main class="page">
    <!-- Hero -->
    <section class="investor-hero animate-in">
      <div class="badge">
        <span class="badge-dot"></span>
        <span>Seed Round — $5M</span>
      </div>
      <h1 class="page-title">
        Join the <span class="electric-text">Seed Phase</span>
      </h1>
      <p class="page-subtitle">
        InnovativeDynamix is raising $5M for Fluidity Marine to develop ABLTV —
        Active Boundary Layer Thrust Vectoring — a rudderless marine propulsion system.
      </p>
    </section>

    <!-- Quick Stats -->
    <section class="stats-grid animate-in delay-1">
      <div class="stat-card glass-box">
        <span class="stat-card-label">Target</span>
        <span class="stat-card-value">$5,000,000</span>
      </div>
      <div class="stat-card glass-box">
        <span class="stat-card-label">Instrument</span>
        <span class="stat-card-value">SAFE + Wefunder</span>
      </div>
      <div class="stat-card glass-box">
        <span class="stat-card-label">Technology</span>
        <span class="stat-card-value">ABLTV — 7-jet array</span>
      </div>
      <div class="stat-card glass-box">
        <span class="stat-card-label">IP</span>
        <span class="stat-card-value">5 patent filings</span>
      </div>
    </section>

    <!-- About the Round -->
    <hr class="divider" />
    <section class="thesis-section animate-in delay-2">
      <h2 class="section-title">About the Round</h2>
      <p class="section-subtitle">Fluidity Marine is raising seed capital to bring ABLTV from concept to operational prototype.</p>
      <div class="glass-box">
        <p>Fluidity Marine (a division of InnovativeDynamix) is developing the first rudderless marine propulsion system using Active Boundary Layer Thrust Vectoring. The technology replaces the mechanical rudder with a synchronized array of 7 water jets at the transom, controlled by a 2,000Hz digital control loop.</p>
        <p style="margin-top: 1.5rem;">Funds will be used for prototype manufacturing, on-water testing, intellectual property protection, and team expansion. Specific financial projections, use-of-funds breakdown, and detailed terms are available upon request.</p>
      </div>
    </section>

    <!-- SAFE Terms (Proposed) -->
    <hr class="divider" />
    <section class="safe-section animate-in delay-2">
      <h2 class="section-title">Proposed SAFE Terms</h2>
      <p class="section-subtitle">Indicative terms — subject to negotiation and legal documentation.</p>
      <div class="glass-box">
        <div class="safe-grid">
          <div class="safe-item">
            <span class="safe-label">Instrument Type</span>
            <span class="safe-value">SAFE (YC Standard)</span>
          </div>
          <div class="safe-item">
            <span class="safe-label">Valuation Cap</span>
            <span class="safe-value highlight">$10,000,000</span>
          </div>
          <div class="safe-item">
            <span class="safe-label">Discount Rate</span>
            <span class="safe-value">20%</span>
          </div>
          <div class="safe-item">
            <span class="safe-label">Investment Vehicle</span>
            <span class="safe-value">Wefunder + Private Placement</span>
          </div>
          <div class="safe-item">
            <span class="safe-label">Contact</span>
            <span class="safe-value"><a href="mailto:aaron@fluiditymarine.com" style="color: var(--cyan); text-decoration: none;">aaron@fluiditymarine.com</a></span>
          </div>
        </div>
      </div>
    </section>

    <!-- Team -->
    <hr class="divider" />
    <section class="team-section animate-in delay-2">
      <h2 class="section-title">Team</h2>
      <p class="section-subtitle">The people behind Fluidity Marine.</p>
      <div class="card-grid">
        <div class="card team-card">
          <h3>Aaron Evans</h3>
          <span class="team-role" style="color: var(--cyan); font-size: 0.85rem; display: block; margin-bottom: 1rem;">CEO / Chief Scientist</span>
          <p>Founder of InnovativeDynamix and inventor of the ABLTV platform. Leading the transition from laboratory research to commercial marine propulsion.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <hr class="divider" />
    <section class="cta-section animate-in delay-4">
      <div class="glass-box cta-box">
        <h3>Interested in Learning More?</h3>
        <p>Contact Aaron Evans directly for the pitch deck, financial model, and terms.</p>
        <a href="mailto:aaron@fluiditymarine.com" class="button button-primary">Email aaron@fluiditymarine.com →</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .investor-hero { margin-bottom: 3rem; }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 5rem;
  }

  .stat-card {
    text-align: center;
    padding: 1.5rem;
  }

  .stat-card-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted, #8899b4);
    margin-bottom: 0.5rem;
  }

  .stat-card-value {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--cyan, #00F0FF);
  }

  .safe-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .safe-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .safe-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted, #8899b4);
  }

  .safe-value {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
  }

  .safe-value.highlight {
    color: var(--cyan, #00F0FF);
    font-size: 1.3rem;
  }

  .team-card { padding: 1.5rem; }

  .cta-box {
    text-align: center;
    padding: 4rem;
  }

  .cta-box h3 {
    font-size: 1.8rem;
    color: #fff;
    margin: 0 0 1rem;
  }

  .cta-box p {
    color: var(--text-muted, #8899b4);
    font-size: 1rem;
    max-width: 500px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .safe-grid { grid-template-columns: 1fr; }
    .cta-box { padding: 2.5rem 1.5rem; }
  }
</style>
