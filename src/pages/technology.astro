---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ABLTV Technology | Fluidity Marine — Active Boundary Layer Thrust Vectoring">
  <main class="page">
    <!-- Hero -->
    <section class="tech-hero animate-in">
      <h1 class="page-title">
        Active Boundary Layer<br />
        <span class="electric-text">Thrust Vectoring</span>
      </h1>
      <p class="page-subtitle">
        The culmination of digital fluid dynamic control. ABLTV replaces every mechanical control surface 
        on a marine vessel with directed fluid power. Seven synchronized jets. Two thousand decisions per second. 
        <strong>Zero rudders.</strong> Pure fluid intelligence.
      </p>
    </section>

    <!-- ABLTV Diagram -->
    <section class="diagram-section animate-in delay-1">
      <div class="diagram-container">
        <div class="hull-profile">
          <!-- SVG: Overhead (simulator rotated 90° — bow left) + Rear (aft view, jets along bottom of transom) -->
          <svg viewBox="0 0 800 420" fill="none" xmlns="http://www.w3.org/2000/svg" class="tech-diagram">
            <!-- ════════════════════════════════════════ -->
            <!-- TOP SECTION: Overhead View             -->
            <!-- ════════════════════════════════════════ -->
            
            <!-- Label -->
            <rect x="20" y="10" width="200" height="26" rx="13" fill="rgba(0,240,255,0.08)" stroke="rgba(0,240,255,0.15)" stroke-width="1"/>
            <text x="120" y="28" text-anchor="middle" fill="#00F0FF" font-size="11" font-weight="700" font-family="Inter" letter-spacing="0.06em">OVERHEAD VIEW</text>

            <!-- Hull exactly like simulator, rotated 90°: bow LEFT, transom RIGHT -->
            <path d="M80 190 L580 140 L660 140 L720 190 L720 240 L660 290 L580 290 Z" 
                  fill="url(#hullGrad)" stroke="rgba(0,240,255,0.25)" stroke-width="1.5"/>
            
            <!-- Cabin/wheelhouse (like simulator's rect(-22, -35, 44, 70, 5)) -->
            <rect x="380" y="195" width="120" height="40" rx="6" fill="rgba(15,23,42,0.6)" stroke="rgba(0,240,255,0.12)" stroke-width="1"/>

            <!-- 7 jets in a straight VERTICAL line at transom (right side) -->
            <circle cx="716" cy="198" r="9" fill="rgba(0,240,255,0.2)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="716" y="201" text-anchor="middle" fill="#00F0FF" font-size="8" font-weight="700" font-family="Inter">1</text>
            <circle cx="716" cy="212" r="9" fill="rgba(0,240,255,0.2)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="716" y="215" text-anchor="middle" fill="#00F0FF" font-size="8" font-weight="700" font-family="Inter">2</text>
            <circle cx="716" cy="226" r="9" fill="rgba(0,240,255,0.2)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="716" y="229" text-anchor="middle" fill="#00F0FF" font-size="8" font-weight="700" font-family="Inter">3</text>
            <circle cx="716" cy="240" r="9" fill="rgba(255,184,0,0.25)" stroke="#FFB800" stroke-width="1.5"/>
            <text x="716" y="243" text-anchor="middle" fill="#FFB800" font-size="8" font-weight="700" font-family="Inter">4</text>
            <circle cx="716" cy="254" r="9" fill="rgba(0,240,255,0.2)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="716" y="257" text-anchor="middle" fill="#00F0FF" font-size="8" font-weight="700" font-family="Inter">5</text>
            <circle cx="716" cy="268" r="9" fill="rgba(0,240,255,0.2)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="716" y="271" text-anchor="middle" fill="#00F0FF" font-size="8" font-weight="700" font-family="Inter">6</text>
            <circle cx="716" cy="282" r="9" fill="rgba(0,240,255,0.2)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="716" y="285" text-anchor="middle" fill="#00F0FF" font-size="8" font-weight="700" font-family="Inter">7</text>

            <!-- Jet streams flowing right from each node -->
            <path d="M725 198 C745 196, 765 194, 785 192" stroke="#00F0FF" stroke-width="1.5" stroke-linecap="round" opacity="0.4" fill="none"/>
            <path d="M725 212 C745 211, 765 209, 785 207" stroke="#00F0FF" stroke-width="1.5" stroke-linecap="round" opacity="0.35" fill="none"/>
            <path d="M725 240 C745 240, 765 239, 785 238" stroke="#FFB800" stroke-width="2" stroke-linecap="round" opacity="0.4" fill="none"/>
            <path d="M725 268 C745 269, 765 269, 785 269" stroke="#00F0FF" stroke-width="1.5" stroke-linecap="round" opacity="0.3" fill="none"/>
            <path d="M725 282 C745 284, 765 286, 785 288" stroke="#00F0FF" stroke-width="1.5" stroke-linecap="round" opacity="0.25" fill="none"/>

            <!-- Labels -->
            <text x="80" y="215" fill="rgba(148,163,184,0.4)" font-size="10" font-family="Inter">Bow</text>
            <text x="720" y="165" fill="#00F0FF" font-size="10" font-weight="600" font-family="Inter" text-anchor="middle">7× Jet Array on Transom</text>
            <text x="390" y="240" fill="rgba(148,163,184,0.3)" font-size="9" font-family="Inter" text-anchor="middle">Wheelhouse</text>

            <!-- ════════════════════════════════════════ -->
            <!-- BOTTOM SECTION: Rear View              -->
            <!-- ════════════════════════════════════════ -->

            <!-- Label -->
            <rect x="20" y="300" width="200" height="26" rx="13" fill="rgba(0,240,255,0.08)" stroke="rgba(0,240,255,0.15)" stroke-width="1"/>
            <text x="120" y="318" text-anchor="middle" fill="#00F0FF" font-size="11" font-weight="700" font-family="Inter" letter-spacing="0.06em">REAR VIEW — STERN</text>

            <!-- Hull aft view (looking at transom from behind) -->
            <!-- Deck top -->
            <line x1="280" y1="335" x2="500" y2="335" stroke="rgba(0,240,255,0.15)" stroke-width="2"/>
            
            <!-- Transom face -->
            <rect x="320" y="335" width="140" height="30" rx="2" fill="rgba(15,23,42,0.7)" stroke="rgba(0,240,255,0.2)" stroke-width="1.5"/>

            <!-- Hull sides tapering downward (V-shape below transom) -->
            <path d="M280 335 L200 400 L580 400 L500 335" fill="rgba(10,18,30,0.5)" stroke="rgba(0,240,255,0.08)" stroke-width="1"/>
            
            <!-- Keel line (bottom point of V) -->
            <line x1="200" y1="400" x2="580" y2="400" stroke="rgba(0,240,255,0.1)" stroke-width="1" stroke-dasharray="3,3"/>

            <!-- Waterline -->
            <line x1="220" y1="370" x2="560" y2="370" stroke="rgba(0,240,255,0.15)" stroke-width="1" stroke-dasharray="5,3"/>
            <text x="575" y="373" fill="rgba(148,163,184,0.3)" font-size="9" font-family="Inter">Waterline</text>

            <!-- 7 Jets in horizontal line along BOTTOM of transom -->
            <circle cx="328" cy="362" r="8" fill="rgba(0,240,255,0.2)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="328" y="365" text-anchor="middle" fill="#00F0FF" font-size="7" font-weight="700" font-family="Inter">1</text>
            <circle cx="348" cy="362" r="8" fill="rgba(0,240,255,0.2)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="348" y="365" text-anchor="middle" fill="#00F0FF" font-size="7" font-weight="700" font-family="Inter">2</text>
            <circle cx="368" cy="362" r="8" fill="rgba(0,240,255,0.2)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="368" y="365" text-anchor="middle" fill="#00F0FF" font-size="7" font-weight="700" font-family="Inter">3</text>
            <circle cx="388" cy="362" r="8" fill="rgba(255,184,0,0.25)" stroke="#FFB800" stroke-width="1.5"/>
            <text x="388" y="365" text-anchor="middle" fill="#FFB800" font-size="7" font-weight="700" font-family="Inter">4</text>
            <circle cx="408" cy="362" r="8" fill="rgba(0,240,255,0.2)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="408" y="365" text-anchor="middle" fill="#00F0FF" font-size="7" font-weight="700" font-family="Inter">5</text>
            <circle cx="428" cy="362" r="8" fill="rgba(0,240,255,0.2)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="428" y="365" text-anchor="middle" fill="#00F0FF" font-size="7" font-weight="700" font-family="Inter">6</text>
            <circle cx="448" cy="362" r="8" fill="rgba(0,240,255,0.2)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="448" y="365" text-anchor="middle" fill="#00F0FF" font-size="7" font-weight="700" font-family="Inter">7</text>

            <!-- Labels -->
            <text x="200" y="405" fill="rgba(148,163,184,0.3)" font-size="9" font-family="Inter">Keel</text>
            <text x="390" y="330" text-anchor="middle" fill="#00F0FF" font-size="10" font-weight="600" font-family="Inter">Deck</text>
            <text x="390" y="415" text-anchor="middle" fill="rgba(148,163,184,0.5)" font-size="10" font-family="Inter">7 Jets Along Bottom of Transom</text>

            <defs>
              <linearGradient id="hullGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="rgba(15,23,42,0.6)"/>
                <stop offset="50%" stop-color="rgba(30,41,59,0.4)"/>
                <stop offset="100%" stop-color="rgba(15,23,42,0.6)"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="content-section animate-in delay-2">
      <h2 class="section-title">How It Works</h2>
      <p class="section-subtitle">Three principles that make ABLTV a paradigm shift in maritime propulsion.</p>

      <div class="card-grid">
        <div class="card principle-card">
          <div class="principle-number">01</div>
          <h3>Node Synchronization</h3>
          <p>A synchronized array of 7 high-pressure thrust nodes is embedded at the transom line. Each node operates independently, controlled by a real-time digital loop running at <strong>2,000Hz</strong>.</p>
        </div>

        <div class="card principle-card">
          <div class="principle-number">02</div>
          <h3>Differential Drag Modulation</h3>
          <p>Steering is achieved not by turning a mechanical rudder, but by micro-adjusting thrust intensity on individual nodes. This selectively increases or decreases drag at specific boundary layer coordinates, inducing yaw without appendages.</p>
        </div>

        <div class="card principle-card">
          <div class="principle-number">03</div>
          <h3>Software-Defined Vectoring</h3>
          <p>Yaw, pitch, and roll vectors are calculated and executed in software. No mechanical linkages, no moving parts below the waterline — just digital precision controlling fluid dynamics at the interface.</p>
        </div>
      </div>
    </section>

    <!-- Boundary Layer Physics -->
    <hr class="divider" />
    <section class="content-section animate-in delay-2">
      <h2 class="section-title">Boundary Layer Physics</h2>
      <p class="section-subtitle">Why the thin film of water along your hull is the most powerful steering lever ever discovered.</p>

      <div class="physics-grid">
        <div class="glass-box physics-card">
          <h3>What is the Boundary Layer?</h3>
          <p>Every boat moving through water drags a thin sheet of water along its hull — typically 5–30 mm thick depending on speed and hull shape. Inside this sheet, water velocity transitions from zero (right at the hull surface) to the full freestream velocity. Think of it as a "skin" of slower-moving water that the boat carries with it.</p>
          <p class="physics-highlight">ABLTV doesn't fight the ocean. It pushes against the thin film of water already attached to its own hull.</p>
        </div>

        <div class="glass-box physics-card physics-full">
          <h3>The Physics of Boundary Layer Control</h3>
          <p>Every vessel moving through water drags a thin film of water along its hull. By injecting precisely controlled jets into this boundary layer, ABLTV can alter the pressure distribution across the stern — inducing a turning moment without any mechanical rudder surface.</p>
          <p style="margin-top: 1rem;">This is not a minor improvement on existing steering technology — it is a fundamentally different approach. Where a rudder creates drag to steer, ABLTV redirects energy already in the water column.</p>
        </div>

        <div class="glass-box physics-card physics-full">
          <h3>How Jet Vectoring Works</h3>
          <p>When the ECU commands a turn to starboard:</p>
          <ol class="physics-steps">
            <li><strong>Port-side jets (J1–J3)</strong> increase thrust and vector aft-starboard — accelerating the boundary layer on the port side</li>
            <li><strong>Starboard-side jets (J5–J7)</strong> reduce thrust and vector aft-port — decelerating the boundary layer on the starboard side</li>
            <li><strong>Center jet (J4)</strong> splits the difference — adding or subtracting based on demanded turn rate</li>
          </ol>
          <p>The result: a <strong>pressure differential</strong> across the stern that smoothly rotates the vessel — controlled entirely in software, with no mechanical linkages below the waterline.</p>
        </div>
      </div>
    </section>

    <!-- The Problem We Solve -->
    <hr class="divider" />
    <section class="content-section animate-in delay-3">
      <div class="comparison-grid">
        <div class="comparison-card old-way">
          <div class="comparison-label">The Appendage Era</div>
          <h3>Traditional Propulsion</h3>
          <ul>
            <li>Mechanical rudders create parasitic drag</li>
            <li>Up to <strong>12% energy loss</strong> from rudder surface area</li>
            <li><strong>60%</strong> of small-vessel engine failures linked to mechanical linkage or propeller/rudder snagging</li>
            <li>Complex steerable units below waterline</li>
            <li>Centralized industrial manufacturing required</li>
          </ul>
        </div>

        <div class="comparison-card new-way">
          <div class="comparison-label electric-text">The Modulator Era</div>
          <h3>ABLTV Propulsion</h3>
          <ul>
            <li>Zero mechanical appendages below waterline</li>
            <li>Boundary layer modulation eliminates drag surface</li>
            <li>No moving parts below water = near-zero underwater maintenance</li>
            <li>Modular architecture</li>
            <li>Regional manufacturing hubs enabled</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Investor CTA -->
    <hr class="divider" />
    <section class="content-section animate-in delay-4">
      <div class="glass-box cta-box">
        <h3>Investor Information</h3>
        <p>Fluidity Marine is raising a $5M Seed round. Learn more about the technology, team, and terms.</p>
        <a href="/investors" class="button button-primary">View Investor Page →</a>
        <a href="/tools/simulator.html" class="button button-secondary" style="margin-left: 1rem;">Launch Simulator</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ─── Tech Hero ─── */
  .tech-hero { margin-bottom: 3rem; }

  /* ─── Diagram ─── */
  .diagram-section { margin-bottom: 5rem; }

  .diagram-container {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 2rem;
    overflow: hidden;
  }

  .tech-diagram { width: 100%; height: auto; }

  /* ─── Principle Cards ─── */
  .principle-card { position: relative; padding-top: 3.5rem; }

  .principle-number {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-size: 2.5rem;
    font-weight: 900;
    color: rgba(0, 240, 255, 0.08);
    line-height: 1;
  }

  /* ─── Physics Section ─── */
  .physics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .physics-card {
    padding: 2rem;
  }

  .physics-card h3 {
    font-size: 1.2rem;
    color: #fff;
    margin: 0 0 1rem;
  }

  .physics-card p {
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 0.95rem;
    margin: 0;
  }

  .physics-card p + p { margin-top: 1rem; }

  .physics-highlight {
    background: rgba(0, 240, 255, 0.06);
    border-left: 3px solid var(--cyan);
    padding: 1rem 1.2rem;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-weight: 600;
    color: var(--cyan) !important;
  }

  .physics-full { grid-column: 1 / -1; }

  /* ─── Comparison Grid ─── */
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .comparison-card {
    padding: 2.5rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border);
  }

  .comparison-card.old-way { background: rgba(255, 255, 255, 0.02); }

  .comparison-card.new-way {
    background: rgba(0, 240, 255, 0.03);
    border-color: rgba(0, 240, 255, 0.15);
  }

  .comparison-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text-muted);
  }

  .comparison-card h3 {
    font-size: 1.5rem;
    color: #fff;
    margin: 0 0 1.5rem;
  }

  .comparison-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .comparison-card li {
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    position: relative;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .comparison-card li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--cyan);
  }

  .comparison-card.new-way li::before {
    content: '✓';
    color: var(--cyan);
  }

  .comparison-card strong { color: var(--text); }

  /* ─── CTA Box ─── */
  .cta-box {
    text-align: center;
    padding: 4rem;
  }

  .cta-box h3 {
    font-size: 1.8rem;
    color: #fff;
    margin: 0 0 1rem;
  }

  .cta-box p {
    color: var(--text-muted);
    font-size: 1rem;
    max-width: 550px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .physics-grid { grid-template-columns: 1fr; }
    .comparison-grid { grid-template-columns: 1fr; }
    .cta-box { padding: 2.5rem 1.5rem; }
    .cta-box .button-secondary { margin-left: 0 !important; margin-top: 1rem; }
  }
</style>
