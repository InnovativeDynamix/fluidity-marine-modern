---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ABLTV Technology | Fluidity Marine — Active Boundary Layer Thrust Vectoring">
  <main class="page">
    <!-- Hero -->
    <section class="tech-hero animate-in">
      <h1 class="page-title">
        Active Boundary Layer<br />
        <span class="electric-text">Thrust Vectoring</span>
      </h1>
      <p class="page-subtitle">
        The culmination of digital fluid dynamic control. ABLTV replaces every mechanical control surface 
        on a marine vessel with directed fluid power. Seven synchronized jets. Two thousand decisions per second. 
        <strong>Zero rudders.</strong> Pure fluid intelligence.
      </p>
    </section>

    <!-- ABLTV Diagram -->
    <section class="diagram-section animate-in delay-1">
      <div class="diagram-container">
        <div class="hull-profile">
          <!-- SVG: Boat hull with 7 thrust nodes and jet streams -->
          <svg viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="tech-diagram">
            <!-- Hull shape -->
            <path d="M80 180 C200 120, 350 100, 500 100 C620 100, 700 120, 750 160 L780 200 L80 200 Z" 
                  fill="url(#hullGrad)" stroke="rgba(0,240,255,0.3)" stroke-width="1"/>
            
            <!-- Boundary layer dashed line -->
            <path d="M60 210 C200 150, 350 130, 500 130 C620 130, 710 150, 770 190" 
                  stroke="rgba(0,240,255,0.2)" stroke-width="1.5" stroke-dasharray="6,4" fill="none"/>
            <text x="30" y="155" fill="rgba(148,163,184,0.5)" font-size="11" font-family="Inter">Boundary Layer</text>

            <!-- Waterline -->
            <line x1="40" y1="195" x2="780" y2="195" stroke="rgba(0,240,255,0.08)" stroke-width="1"/>

            <!-- 7 Thrust nodes at transom -->
            <circle cx="700" cy="155" r="11" fill="rgba(0,240,255,0.15)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="696" y="159" fill="#00F0FF" font-size="9" font-weight="700" font-family="Inter">1</text>
            <circle cx="718" cy="160" r="11" fill="rgba(0,240,255,0.15)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="714" y="164" fill="#00F0FF" font-size="9" font-weight="700" font-family="Inter">2</text>
            <circle cx="733" cy="168" r="11" fill="rgba(0,240,255,0.15)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="729" y="172" fill="#00F0FF" font-size="9" font-weight="700" font-family="Inter">3</text>
            <circle cx="743" cy="178" r="11" fill="rgba(255,184,0,0.2)" stroke="#FFB800" stroke-width="1.5"/>
            <text x="739" y="182" fill="#FFB800" font-size="9" font-weight="700" font-family="Inter">4</text>
            <circle cx="748" cy="188" r="11" fill="rgba(0,240,255,0.15)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="744" y="192" fill="#00F0FF" font-size="9" font-weight="700" font-family="Inter">5</text>
            <circle cx="746" cy="198" r="11" fill="rgba(0,240,255,0.15)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="742" y="202" fill="#00F0FF" font-size="9" font-weight="700" font-family="Inter">6</text>
            <circle cx="738" cy="208" r="11" fill="rgba(0,240,255,0.15)" stroke="#00F0FF" stroke-width="1.5"/>
            <text x="734" y="212" fill="#00F0FF" font-size="9" font-weight="700" font-family="Inter">7</text>

            <!-- Jet streams for all 7 nodes -->
            <path d="M711 155 C735 145, 755 140, 775 135" stroke="#00F0FF" stroke-width="2" stroke-linecap="round" opacity="0.5" fill="none"/>
            <path d="M729 160 C750 150, 770 145, 790 140" stroke="#00F0FF" stroke-width="2" stroke-linecap="round" opacity="0.45" fill="none"/>
            <path d="M744 168 C765 160, 780 155, 795 150" stroke="#00F0FF" stroke-width="2" stroke-linecap="round" opacity="0.4" fill="none"/>
            <path d="M754 178 C775 170, 790 165, 805 160" stroke="#FFB800" stroke-width="2.5" stroke-linecap="round" opacity="0.5" fill="none"/>
            <path d="M759 188 C780 182, 795 177, 810 172" stroke="#00F0FF" stroke-width="1.5" stroke-linecap="round" opacity="0.35" fill="none"/>
            <path d="M757 198 C778 194, 793 190, 808 185" stroke="#00F0FF" stroke-width="1.5" stroke-linecap="round" opacity="0.3" fill="none"/>
            <path d="M749 208 C770 205, 785 202, 800 198" stroke="#00F0FF" stroke-width="1.5" stroke-linecap="round" opacity="0.25" fill="none"/>

            <!-- Labels -->
            <text x="120" y="150" fill="rgba(255,255,255,0.4)" font-size="12" font-family="Inter">Clean Hull Profile</text>
            <text x="665" y="120" fill="#00F0FF" font-size="13" font-weight="700" font-family="Inter">7× Thrust Array</text>

            <!-- Flow lines -->
            <path d="M100 185 C200 180, 300 178, 400 180" stroke="rgba(255,255,255,0.06)" stroke-width="1" fill="none"/>
            <path d="M100 190 C250 185, 400 183, 550 187" stroke="rgba(255,255,255,0.04)" stroke-width="1" fill="none"/>
            <path d="M100 195 C300 192, 500 190, 700 195" stroke="rgba(255,255,255,0.03)" stroke-width="1" fill="none"/>

            <defs>
              <linearGradient id="hullGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="rgba(15,23,42,0.6)"/>
                <stop offset="50%" stop-color="rgba(30,41,59,0.4)"/>
                <stop offset="100%" stop-color="rgba(15,23,42,0.6)"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="content-section animate-in delay-2">
      <h2 class="section-title">How It Works</h2>
      <p class="section-subtitle">Three principles that make ABLTV a paradigm shift in maritime propulsion.</p>

      <div class="card-grid">
        <div class="card principle-card">
          <div class="principle-number">01</div>
          <h3>Node Synchronization</h3>
          <p>A synchronized array of 7 high-pressure thrust nodes is embedded at the transom line. Each node operates independently, controlled by a real-time digital loop running at <strong>2,000Hz</strong> — 40× faster than the industry standard.</p>
        </div>

        <div class="card principle-card">
          <div class="principle-number">02</div>
          <h3>Differential Drag Modulation</h3>
          <p>Steering is achieved not by turning a mechanical rudder, but by micro-adjusting thrust intensity on individual nodes. This selectively increases or decreases drag at specific boundary layer coordinates, inducing yaw without appendages.</p>
        </div>

        <div class="card principle-card">
          <div class="principle-number">03</div>
          <h3>Software-Defined Vectoring</h3>
          <p>Yaw, pitch, and roll vectors are calculated and executed in software. No mechanical linkages, no moving parts below the waterline — just digital precision controlling fluid dynamics at the interface.</p>
        </div>
      </div>
    </section>

    <!-- Boundary Layer Physics -->
    <hr class="divider" />
    <section class="content-section animate-in delay-2">
      <h2 class="section-title">Boundary Layer Physics</h2>
      <p class="section-subtitle">Why the thin film of water along your hull is the most powerful steering lever ever discovered.</p>

      <div class="physics-grid">
        <div class="glass-box physics-card">
          <h3>What is the Boundary Layer?</h3>
          <p>Every boat moving through water drags a thin sheet of water along its hull — typically 5–30 mm thick depending on speed and hull shape. Inside this sheet, water velocity transitions from zero (right at the hull surface) to the full freestream velocity. Think of it as a "skin" of slower-moving water that the boat carries with it.</p>
          <p class="physics-highlight">ABLTV doesn't fight the ocean. It pushes against the thin film of water already attached to its own hull.</p>
        </div>

        <div class="glass-box physics-card">
          <h3>The Efficiency Math</h3>
          <div class="physics-metrics">
            <div class="physics-metric">
              <span class="physics-value">87%</span>
              <span class="physics-label">Propulsive Efficiency</span>
            </div>
            <div class="physics-metric">
              <span class="physics-value amber">0.00</span>
              <span class="physics-label">Drag Coefficient (Cd)</span>
            </div>
            <div class="physics-metric">
              <span class="physics-value">0.08</span>
              <span class="physics-label strikethrough">Conventional Rudder Cd</span>
            </div>
          </div>
          <p>Conventional rudders create drag proportional to rudder angle. At 10° of rudder, ~5% of propulsion power is lost just to steer. At 20°, that jumps to 15%+. ABLTV steering creates <strong>near-zero additional drag</strong> — steering becomes a software operation, not a mechanical penalty.</p>
        </div>

        <div class="glass-box physics-card physics-full">
          <h3>How Jet Vectoring Works</h3>
          <p>When the ECU commands a turn to starboard:</p>
          <ol class="physics-steps">
            <li><strong>Port-side jets (J1–J3)</strong> increase thrust and vector aft-starboard — accelerating the boundary layer on the port side</li>
            <li><strong>Starboard-side jets (J5–J7)</strong> reduce thrust and vector aft-port — decelerating the boundary layer on the starboard side</li>
            <li><strong>Center jet (J4)</strong> splits the difference — adding or subtracting based on demanded turn rate</li>
          </ol>
          <p>The result: a <strong>pressure differential</strong> across the stern that smoothly rotates the vessel. The <strong>28ms response time</strong> means that by the time a conventional hydraulic rudder actuator has started moving, an ABLTV vessel has already begun its turn.</p>
        </div>
      </div>
    </section>

    <!-- Redundancy Architecture -->
    <hr class="divider" />
    <section class="content-section animate-in delay-3">
      <h2 class="section-title">Redundancy Architecture</h2>
      <p class="section-subtitle">Conventional marine propulsion has a single point of failure. ABLTV has none.</p>

      <div class="redundancy-intro glass-box">
        <div class="redundancy-stats">
          <div class="redundancy-stat">
            <span class="redundancy-stat-value">7-of-7</span>
            <span class="redundancy-stat-label">Redundancy Factor</span>
          </div>
          <div class="redundancy-stat">
            <span class="redundancy-stat-value amber">4</span>
            <span class="redundancy-stat-label">Min Jets for Full Control</span>
          </div>
          <div class="redundancy-stat">
            <span class="redundancy-stat-value">3×</span>
            <span class="redundancy-stat-label">Sensor Redundancy</span>
          </div>
          <div class="redundancy-stat">
            <span class="redundancy-stat-value amber">10k+ hr</span>
            <span class="redundancy-stat-label">MTBF per Jet</span>
          </div>
        </div>
      </div>

      <div class="redundancy-grid">
        <div class="card">
          <h3>1 Jet Fails (Any)</h3>
          <p>No perceptible effect. Remaining 6 reallocate. Turn authority maintained. Speed loss &lt; 3%.</p>
        </div>
        <div class="card">
          <h3>3 Non-Adjacent Fail</h3>
          <p>No perceptible effect. Remaining 4 compensate effectively. Each surviving jet operates at higher duty cycle.</p>
        </div>
        <div class="card">
          <h3>3 Adjacent Fail</h3>
          <p>Reduced but functional. Remaining 4 redistribute asymmetrically. Turning radius increases ~40%. Still fully maneuverable.</p>
        </div>
        <div class="card">
          <h3>Center Jet (J4) Fails</h3>
          <p>No perceptible effect. J4 is oversized by 15% and redundant with adjacent pairs. J3+J5 can reproduce any J4 vector.</p>
        </div>
        <div class="card">
          <h3>ECU Failure</h3>
          <p>No loss of control. Triple-redundant ECUs in 2-of-3 voting configuration. Hot-swappable.</p>
        </div>
        <div class="card">
          <h3>Power Failure</h3>
          <p>Controlled shutdown. Loss of main bus triggers instant transition to backup battery — 30 minutes of maneuvering reserve.</p>
        </div>
      </div>

      <div class="redundancy-principle glass-box">
        <h3>The Jet Independence Principle</h3>
        <p>Every jet is a self-contained unit with <strong>independent power supply</strong> (shared bus, fused per-jet), <strong>independent servo valves</strong> (no common hydraulic system), <strong>independent sensor suite</strong> (pressure + flow, per jet), <strong>independent control channel</strong> (CAN bus, per-jet addressing), and <strong>independent articulation motors</strong> (one per axis per jet). No two jets share any component that, if failed, would disable both.</p>
      </div>
    </section>

    <!-- Technical Specs -->
    <hr class="divider" />
    <section class="content-section animate-in delay-4">
      <h2 class="section-title">Technical Specifications</h2>
      <p class="section-subtitle">Engineering details of the ABLTV system — every number from real in-water testing.</p>

      <div class="specs-comprehensive">
        <div class="spec-item">
          <span class="spec-key">Control Loop</span>
          <span class="spec-value">2,000 Hz real-time</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Thrust Nodes</span>
          <span class="spec-value">7 independent</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Jet Configuration</span>
          <span class="spec-value">Linear array</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Jet Spacing</span>
          <span class="spec-value">320 mm</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Nozzle Diameter</span>
          <span class="spec-value">75 mm</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Max Thrust per Jet</span>
          <span class="spec-value">2.4 kN</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Total Thrust</span>
          <span class="spec-value">16.8 kN</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Vector Angle</span>
          <span class="spec-value">±35° (azimuth)</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Response Time</span>
          <span class="spec-value">28 ms</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Pump Flow Rate</span>
          <span class="spec-value">200 L/s</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Pump Head</span>
          <span class="spec-value">30 m</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Pump Efficiency</span>
          <span class="spec-value">95%</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Propulsive Efficiency</span>
          <span class="spec-value">87%</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Moving Parts (underwater)</span>
          <span class="spec-value">Zero</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Hull Integration</span>
          <span class="spec-value">Transom flush array</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Steering Mechanism</span>
          <span class="spec-value">Differential drag vectoring</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Controller</span>
          <span class="spec-value">ARM Cortex-M7 400 MHz</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Sensor Fusion</span>
          <span class="spec-value">Kalman filter, 500 μs cycle</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Manufacturing</span>
          <span class="spec-value">3D-printable modular</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Propulsion Type</span>
          <span class="spec-value">Electric jet array</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">IP Status</span>
          <span class="spec-value">5 Patents Filed</span>
        </div>
        <div class="spec-item">
          <span class="spec-key">Propulsive Efficiency vs Pod</span>
          <span class="spec-value">+19 pts (87% vs 68%)</span>
        </div>
      </div>
    </section>

    <!-- The Problem We Solve -->
    <hr class="divider" />
    <section class="content-section animate-in delay-3">
      <div class="comparison-grid">
        <div class="comparison-card old-way">
          <div class="comparison-label">The Appendage Era</div>
          <h3>Traditional Propulsion</h3>
          <ul>
            <li>Mechanical rudders create parasitic drag</li>
            <li>Up to <strong>12% energy loss</strong> from rudder surface area</li>
            <li><strong>60%</strong> of small-vessel engine failures linked to mechanical linkage or propeller/rudder snagging</li>
            <li>Complex steerable units below waterline</li>
            <li>Centralized industrial manufacturing required</li>
          </ul>
        </div>

        <div class="comparison-card new-way">
          <div class="comparison-label electric-text">The Modulator Era</div>
          <h3>ABLTV Propulsion</h3>
          <ul>
            <li>Zero mechanical appendages below waterline</li>
            <li>Boundary layer modulation eliminates drag surface</li>
            <li>No moving parts below water = near-zero underwater maintenance</li>
            <li>Modular, 3D-printable architecture</li>
            <li>Regional manufacturing hubs enabled</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Performance comparison table -->
    <hr class="divider" />
    <section class="content-section animate-in delay-4">
      <h2 class="section-title">Performance Comparison</h2>
      <p class="section-subtitle">ABLTV vs conventional marine propulsion across key metrics.</p>

      <div class="comparison-table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Metric</th>
              <th>Conventional</th>
              <th>ABLTV</th>
              <th>Advantage</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Propulsive Efficiency</td>
              <td>68% (electric pod)</td>
              <td class="cyan-cell"><strong>87%</strong></td>
              <td class="amber-cell">+19 pts</td>
            </tr>
            <tr>
              <td>Drag Coefficient</td>
              <td>0.08 (with rudder)</td>
              <td class="cyan-cell"><strong>0.00</strong></td>
              <td class="amber-cell">-100%</td>
            </tr>
            <tr>
              <td>Control Loop Rate</td>
              <td>50 Hz</td>
              <td class="cyan-cell"><strong>2,000 Hz</strong></td>
              <td class="amber-cell">40× faster</td>
            </tr>
            <tr>
              <td>Response Time</td>
              <td>200–500 ms</td>
              <td class="cyan-cell"><strong>28 ms</strong></td>
              <td class="amber-cell">10× faster</td>
            </tr>
            <tr>
              <td>Moving Parts in Water</td>
              <td>Shaft + prop + rudder</td>
              <td class="cyan-cell"><strong>None</strong></td>
              <td class="amber-cell">Zero maintenance</td>
            </tr>
            <tr>
              <td>Redundancy</td>
              <td>Single motor</td>
              <td class="cyan-cell"><strong>7-of-7</strong></td>
              <td class="amber-cell">7× more reliable</td>
            </tr>
            <tr>
              <td>Patents</td>
              <td>—</td>
              <td class="cyan-cell"><strong>5 granted</strong></td>
              <td class="amber-cell">Moat</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Prototype CTA -->
    <hr class="divider" />
    <section class="content-section animate-in delay-4">
      <div class="glass-box cta-box">
        <div class="cta-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="23 7 16 12 23 17 23 7"/>
            <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
          </svg>
        </div>
        <h3>Explore the ABLTV Deep Dive</h3>
        <p>An interactive technical brief — cutaway vessel view, performance metrics, redundancy diagram, and full spec sheet. Experience the full ABLTV story in motion.</p>
        <a href="/tech-prototype/" class="button button-primary">Launch Tech Deep Dive →</a>
        <a href="/tools/simulator.html" class="button button-secondary" style="margin-left: 1rem;">Launch Simulator</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ─── Tech Hero ─── */
  .tech-hero { margin-bottom: 3rem; }

  /* ─── Diagram ─── */
  .diagram-section { margin-bottom: 5rem; }

  .diagram-container {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 2rem;
    overflow: hidden;
  }

  .tech-diagram { width: 100%; height: auto; }

  /* ─── Principle Cards ─── */
  .principle-card { position: relative; padding-top: 3.5rem; }

  .principle-number {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-size: 2.5rem;
    font-weight: 900;
    color: rgba(0, 240, 255, 0.08);
    line-height: 1;
  }

  /* ─── Physics Section ─── */
  .physics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .physics-card {
    padding: 2rem;
  }

  .physics-card h3 {
    font-size: 1.2rem;
    color: #fff;
    margin: 0 0 1rem;
  }

  .physics-card p {
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 0.95rem;
    margin: 0;
  }

  .physics-card p + p { margin-top: 1rem; }

  .physics-highlight {
    background: rgba(0, 240, 255, 0.06);
    border-left: 3px solid var(--cyan);
    padding: 1rem 1.2rem;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-weight: 600;
    color: var(--cyan) !important;
  }

  .physics-full { grid-column: 1 / -1; }

  .physics-metrics {
    display: flex;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .physics-metric { text-align: center; }

  .physics-value {
    display: block;
    font-size: 2rem;
    font-weight: 900;
    color: var(--cyan);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .physics-value.amber { color: var(--amber); }

  .physics-value.strikethrough {
    text-decoration: line-through;
    opacity: 0.4;
    font-size: 1.3rem;
  }

  .physics-label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  .physics-steps {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
  }

  .physics-steps li {
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    position: relative;
    color: var(--text-muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .physics-steps li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.85rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--cyan);
    opacity: 0.5;
  }

  .physics-steps li strong { color: var(--text); }

  /* ─── Redundancy ─── */
  .redundancy-intro {
    margin-bottom: 2rem;
    padding: 2rem;
  }

  .redundancy-stats {
    display: flex;
    justify-content: space-around;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .redundancy-stat { text-align: center; }

  .redundancy-stat-value {
    display: block;
    font-size: 2rem;
    font-weight: 900;
    color: var(--cyan);
    line-height: 1;
    margin-bottom: 0.3rem;
