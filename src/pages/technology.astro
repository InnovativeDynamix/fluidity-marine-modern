---
import Layout from '../layouts/Layout.astro';
import TechDeepDive from '../components/tech/TechDeepDive.astro';
---

<Layout title="Technological Deep Dive | Fluidity Marine">
	<main class="bg-slate-950 min-h-screen">
		<div class="pt-24">
			<TechDeepDive />
		</div>
		
		<section class="mission-cta py-20 bg-blue-900/10 border-t border-blue-900/20">
			<div class="container mx-auto px-4 text-center">
				<h2 class="text-3xl font-bold text-white mb-6">Ready to join the maritime revolution?</h2>
				<a href="https://wefunder.com/fluidity" target="_blank" class="inline-block px-8 py-4 bg-blue-500 hover:bg-blue-400 text-white font-bold rounded-full transition-all">
					Back Fluidity on Wefunder
				</a>
			</div>
		</section>
	</main>
</Layout>

<style>
	main {
		color: white;
	}
</style>
