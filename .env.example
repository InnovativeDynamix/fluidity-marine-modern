# Fluidity Marine Environment Variables Example
# Copy this file to .env and fill in the values

# Site Configuration
PUBLIC_SITE_URL=http://localhost:4321

# Database (Replace with your actual database URL in .env)
DATABASE_URL=postgresql://user:password@localhost:5432/fluidity_marine

# API Keys (Consult documentation for obtaining these)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Authentication
AUTH_SECRET=your_auth_secret_here

# CMS (if applicable)
CONTENTFUL_SPACE_ID=your_space_id
CONTENTFUL_ACCESS_TOKEN=your_access_token
